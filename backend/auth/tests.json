{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/register",
      "body": {"name": "Тест Юзер", "phone": "+79991234567", "email": "test_usdt@example.com", "password": "password123"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login user",
      "method": "POST",
      "path": "/login",
      "body": {"email": "test_usdt@example.com", "password": "password123"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong password",
      "method": "POST",
      "path": "/login",
      "body": {"email": "test_usdt@example.com", "password": "wrongpass"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
